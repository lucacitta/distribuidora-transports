# === Google Sheets ===
# ID del Google Sheet (lo que va entre /d/ y /edit en la URL del sheet).
GOOGLE_SHEET_ID=1IOPXEjWkst7TXuQ_yfBRjSdXc9NUrOwKhgV-zXH_I7o

# Clave de la Service Account (el archivo key.json) codificada en Base64.
# Se usa B64 para no pelear con los saltos de línea del private_key.
#
# Generar el valor:
#   PowerShell (Windows):
#     [Convert]::ToBase64String([IO.File]::ReadAllBytes("key.json"))
#   bash (mac/linux):
#     base64 -w0 key.json
#
# Pegá el resultado (una sola línea) acá:
GOOGLE_SERVICE_ACCOUNT_B64=
